{
  "$defs": {
    "AiConfigComponent": {
      "properties": {
        "config": {
          "anyOf": [
            {
              "$ref": "#/$defs/SearchPolicyConfig"
            },
            {
              "$ref": "#/$defs/HeuristicPolicyConfig"
            }
          ],
          "title": "Config"
        },
        "faction": {
          "$ref": "#/$defs/Faction"
        }
      },
      "required": [
        "config",
        "faction"
      ],
      "title": "AiConfigComponent",
      "type": "object"
    },
    "AssaultControls": {
      "properties": {
        "override": {
          "anyOf": [
            {
              "$ref": "#/$defs/AssaultOutcomes"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "AssaultControls",
      "type": "object"
    },
    "AssaultOutcomes": {
      "description": "Defines an assault outcome as fail or success.",
      "enum": [
        "FAIL",
        "SUCCESS"
      ],
      "title": "AssaultOutcomes",
      "type": "string"
    },
    "CombatUnit": {
      "properties": {
        "faction": {
          "$ref": "#/$defs/Faction"
        },
        "command_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Command Id"
        },
        "status_override": {
          "anyOf": [
            {
              "$ref": "#/$defs/Status"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "faction"
      ],
      "title": "CombatUnit",
      "type": "object"
    },
    "EliminationWinCondition": {
      "properties": {
        "target_faction": {
          "$ref": "#/$defs/Faction"
        },
        "winning_faction": {
          "$ref": "#/$defs/Faction"
        },
        "units_to_eliminate": {
          "title": "Units To Eliminate",
          "type": "integer"
        },
        "units_eliminated_counter": {
          "title": "Units Eliminated Counter",
          "type": "integer"
        }
      },
      "required": [
        "target_faction",
        "winning_faction",
        "units_to_eliminate",
        "units_eliminated_counter"
      ],
      "title": "EliminationWinCondition",
      "type": "object"
    },
    "Entity": {
      "properties": {
        "AiConfigComponent": {
          "anyOf": [
            {
              "$ref": "#/$defs/AiConfigComponent"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Configures AI agent of either BLUE or RED with search policy and state.\nSupports search-based policy or heuristic rule-based policy."
        },
        "Vec2": {
          "anyOf": [
            {
              "$ref": "#/$defs/Vec2"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "2D vector class for basic vector operations"
        },
        "Transform": {
          "anyOf": [
            {
              "$ref": "#/$defs/Transform"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Holds spatial data for 2D entities. Used by rendering, movement,\ncombat mechanics, etc. The existence of this component implies\nthat the entity can be visualized in 2D space."
        },
        "InitiativeState": {
          "anyOf": [
            {
              "$ref": "#/$defs/InitiativeState"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Singleton component that keeps track of faction & initiatives."
        },
        "CombatUnit": {
          "anyOf": [
            {
              "$ref": "#/$defs/CombatUnit"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Marks an entity as a direct combat-capable unit.\nTracks unit suppression and command hierarchy tree."
        },
        "MoveControls": {
          "anyOf": [
            {
              "$ref": "#/$defs/MoveControls"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Marks entity as movable, along with its. Used by move action to\ndetermine which terrain can or cannot cross."
        },
        "FireControls": {
          "anyOf": [
            {
              "$ref": "#/$defs/FireControls"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Marks an entity as capable for fire action.\nDefines the set of outcomes and override."
        },
        "AssaultControls": {
          "anyOf": [
            {
              "$ref": "#/$defs/AssaultControls"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Marks an entity as capable for assault action.\nDefines the RNG roll multiplier."
        },
        "TerrainFeature": {
          "anyOf": [
            {
              "$ref": "#/$defs/TerrainFeature"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Represents a polygonal terrain feature with terrain type bit flags.\nBit flags are used to determine LOS, movement, and fire types."
        },
        "EliminationWinCondition": {
          "anyOf": [
            {
              "$ref": "#/$defs/EliminationWinCondition"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Represents the elimination winning condition for a given faction.\nOnce the provided faction eliminates enough of the target faction,\nthe provided winning faction is considered winner."
        },
        "StallLoseCondition": {
          "anyOf": [
            {
              "$ref": "#/$defs/StallLoseCondition"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Represents stall losing condition for a given faction.\nOnce the faction performs enough stalling moves, the provided\nwinning faction is considered winner."
        }
      },
      "title": "Entity",
      "type": "object"
    },
    "Faction": {
      "enum": [
        "BLUE",
        "RED"
      ],
      "title": "Faction",
      "type": "string"
    },
    "FireControls": {
      "properties": {
        "override": {
          "anyOf": [
            {
              "$ref": "#/$defs/FireOutcomes"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "firing_at": {
          "anyOf": [
            {
              "maxItems": 2,
              "minItems": 2,
              "prefixItems": [
                {
                  "format": "uuid",
                  "type": "string"
                },
                {
                  "$ref": "#/$defs/FireEffect"
                }
              ],
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Firing At"
        }
      },
      "title": "FireControls",
      "type": "object"
    },
    "FireEffect": {
      "description": "Defines all fire effects.",
      "enum": [
        "PINNING",
        "SUPPRESSING"
      ],
      "title": "FireEffect",
      "type": "string"
    },
    "FireOutcomes": {
      "description": "Defines all fire outcomes.",
      "enum": [
        "MISS",
        "PIN",
        "SUPPRESS",
        "KILL"
      ],
      "title": "FireOutcomes",
      "type": "string"
    },
    "FlagPruneConfig": {
      "properties": {
        "type": {
          "const": "FlagPrune",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "title": "FlagPruneConfig",
      "type": "object"
    },
    "GridConfig": {
      "properties": {
        "type": {
          "const": "GridConfig",
          "title": "Type",
          "type": "string"
        },
        "spacing": {
          "title": "Spacing",
          "type": "number"
        },
        "offset": {
          "title": "Offset",
          "type": "number"
        }
      },
      "required": [
        "type",
        "spacing",
        "offset"
      ],
      "title": "GridConfig",
      "type": "object"
    },
    "HandDrawnConfig": {
      "properties": {
        "type": {
          "const": "HandDrawnConfig",
          "title": "Type",
          "type": "string"
        },
        "points": {
          "items": {
            "$ref": "#/$defs/Vec2"
          },
          "title": "Points",
          "type": "array"
        }
      },
      "required": [
        "type",
        "points"
      ],
      "title": "HandDrawnConfig",
      "type": "object"
    },
    "HeuristicPolicyConfig": {
      "properties": {
        "policy_type": {
          "const": "RandomHeuristic",
          "title": "Policy Type",
          "type": "string"
        }
      },
      "required": [
        "policy_type"
      ],
      "title": "HeuristicPolicyConfig",
      "type": "object"
    },
    "InitiativeState": {
      "properties": {
        "faction": {
          "$ref": "#/$defs/Faction",
          "default": "BLUE"
        }
      },
      "title": "InitiativeState",
      "type": "object"
    },
    "LineBasedExpansionConfig": {
      "properties": {
        "type": {
          "const": "LineBased",
          "title": "Type",
          "type": "string"
        },
        "tolerance": {
          "title": "Tolerance",
          "type": "number"
        }
      },
      "required": [
        "type",
        "tolerance"
      ],
      "title": "LineBasedExpansionConfig",
      "type": "object"
    },
    "MoveControls": {
      "properties": {
        "move_type": {
          "$ref": "#/$defs/MoveType",
          "default": "FOOT"
        }
      },
      "title": "MoveControls",
      "type": "object"
    },
    "MoveType": {
      "enum": [
        "FOOT"
      ],
      "title": "MoveType",
      "type": "string"
    },
    "PointsConfig": {
      "properties": {
        "initial_points": {
          "anyOf": [
            {
              "$ref": "#/$defs/GridConfig"
            },
            {
              "$ref": "#/$defs/HandDrawnConfig"
            },
            {
              "$ref": "#/$defs/VoronoiConfig"
            },
            {
              "$ref": "#/$defs/RandomConfig"
            }
          ],
          "title": "Initial Points"
        },
        "use_combat_unit_positions": {
          "title": "Use Combat Unit Positions",
          "type": "boolean"
        },
        "expansions": {
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/LineBasedExpansionConfig"
              },
              {
                "$ref": "#/$defs/PolygonalExpansionConfig"
              },
              {
                "$ref": "#/$defs/FlagPruneConfig"
              },
              {
                "$ref": "#/$defs/WeightsPruneConfig"
              }
            ]
          },
          "title": "Expansions",
          "type": "array"
        }
      },
      "required": [
        "initial_points",
        "use_combat_unit_positions",
        "expansions"
      ],
      "title": "PointsConfig",
      "type": "object"
    },
    "PolygonalExpansionConfig": {
      "properties": {
        "type": {
          "const": "Polygonal",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "title": "PolygonalExpansionConfig",
      "type": "object"
    },
    "RandomConfig": {
      "properties": {
        "type": {
          "const": "Random",
          "title": "Type",
          "type": "string"
        },
        "count": {
          "title": "Count",
          "type": "integer"
        }
      },
      "required": [
        "type",
        "count"
      ],
      "title": "RandomConfig",
      "type": "object"
    },
    "SearchPolicyConfig": {
      "properties": {
        "policy_type": {
          "anyOf": [
            {
              "const": "Minimax",
              "type": "string"
            },
            {
              "const": "Expectimax",
              "type": "string"
            },
            {
              "const": "MCTS",
              "type": "string"
            }
          ],
          "title": "Policy Type"
        },
        "state": {
          "anyOf": [
            {
              "$ref": "#/$defs/WaypointsStateConfig"
            },
            {
              "$ref": "#/$defs/UnabstractedStateConfig"
            }
          ],
          "title": "State"
        }
      },
      "required": [
        "policy_type",
        "state"
      ],
      "title": "SearchPolicyConfig",
      "type": "object"
    },
    "StallLoseCondition": {
      "properties": {
        "counting_faction": {
          "$ref": "#/$defs/Faction"
        },
        "winning_faction": {
          "$ref": "#/$defs/Faction"
        },
        "stall_count": {
          "title": "Stall Count",
          "type": "integer"
        },
        "stall_limit": {
          "title": "Stall Limit",
          "type": "integer"
        }
      },
      "required": [
        "counting_faction",
        "winning_faction",
        "stall_count",
        "stall_limit"
      ],
      "title": "StallLoseCondition",
      "type": "object"
    },
    "Status": {
      "enum": [
        "ACTIVE",
        "PINNED",
        "SUPPRESSED"
      ],
      "title": "Status",
      "type": "string"
    },
    "TerrainFeature": {
      "properties": {
        "vertices": {
          "items": {
            "$ref": "#/$defs/Vec2"
          },
          "title": "Vertices",
          "type": "array"
        },
        "is_closed_loop": {
          "default": true,
          "title": "Is Closed Loop",
          "type": "boolean"
        },
        "flag": {
          "default": -1,
          "title": "Flag",
          "type": "integer"
        }
      },
      "required": [
        "vertices"
      ],
      "title": "TerrainFeature",
      "type": "object"
    },
    "Transform": {
      "properties": {
        "position": {
          "$ref": "#/$defs/Vec2"
        },
        "degrees": {
          "default": 0,
          "title": "Degrees",
          "type": "number"
        }
      },
      "required": [
        "position"
      ],
      "title": "Transform",
      "type": "object"
    },
    "UnabstractedStateConfig": {
      "properties": {
        "type": {
          "const": "UnabstractedStateConfig",
          "title": "Type",
          "type": "string"
        },
        "move_candidates": {
          "$ref": "#/$defs/PointsConfig"
        },
        "divide_moves_per_unit": {
          "title": "Divide Moves Per Unit",
          "type": "boolean"
        }
      },
      "required": [
        "type",
        "move_candidates",
        "divide_moves_per_unit"
      ],
      "title": "UnabstractedStateConfig",
      "type": "object"
    },
    "Vec2": {
      "properties": {
        "x": {
          "title": "X",
          "type": "number"
        },
        "y": {
          "title": "Y",
          "type": "number"
        }
      },
      "required": [
        "x",
        "y"
      ],
      "title": "Vec2",
      "type": "object"
    },
    "VoronoiConfig": {
      "properties": {
        "type": {
          "const": "VoronoiConfig",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "title": "VoronoiConfig",
      "type": "object"
    },
    "WaypointsStateConfig": {
      "properties": {
        "type": {
          "const": "WaypointsStateConfig",
          "title": "Type",
          "type": "string"
        },
        "waypoints": {
          "$ref": "#/$defs/PointsConfig"
        },
        "path_tolerance": {
          "title": "Path Tolerance",
          "type": "number"
        }
      },
      "required": [
        "type",
        "waypoints",
        "path_tolerance"
      ],
      "title": "WaypointsStateConfig",
      "type": "object"
    },
    "WeightsPruneConfig": {
      "properties": {
        "type": {
          "const": "WeightsPrune",
          "title": "Type",
          "type": "string"
        },
        "remaining_size": {
          "title": "Remaining Size",
          "type": "integer"
        }
      },
      "required": [
        "type",
        "remaining_size"
      ],
      "title": "WeightsPruneConfig",
      "type": "object"
    }
  },
  "properties": {
    "entities": {
      "additionalProperties": {
        "$ref": "#/$defs/Entity"
      },
      "propertyNames": {
        "format": "uuid"
      },
      "title": "Entities",
      "type": "object"
    }
  },
  "required": [
    "entities"
  ],
  "title": "EntitiesTable",
  "type": "object"
}